<%- include('../partials/head', { title }) %>
<div class="app-shell">
  <%- include('../partials/nav') %>
  <main class="content">
    <header class="page-header">
      <div>
        <p class="eyebrow">Email Campaigns</p>
        <h1>All Campaigns</h1>
      </div>
      <a href="/campaigns/new" class="button primary">Create Campaign</a>
    </header>

    <%- include('../partials/flash') %>

    <section class="panel">
      <table class="table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Status</th>
            <th>Recipients</th>
            <th>Progress</th>
            <th>Updated</th>
          </tr>
        </thead>
        <tbody>
          <% if (!campaigns.length) { %>
            <tr><td colspan="5">No campaigns created yet.</td></tr>
          <% } %>
          <% campaigns.forEach((campaign) => { %>
            <tr>
              <td><a href="/campaigns/<%= campaign.id %>"><%= campaign.name %></a></td>
              <td><span class="pill"><%= campaign.status %></span></td>
              <td><%= campaign.validRecipients %> valid / <%= campaign.invalidRecipients %> invalid</td>
              <td><%= campaign.sentCount %> sent / <%= campaign.failedCount %> failed</td>
              <td><%= new Date(campaign.updatedAt).toLocaleString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </main>
</div>
<%- include('../partials/footer') %>
